{
  "title": "Kenny's Life",
  "uid": "kenny-life",
  "tags": ["kenny"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Life #",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_life_count_total", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Life duration",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_life_duration_seconds", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "options": {
        "reduceOptions": {"calcs": ["last"]},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Time to death",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_time_to_death_seconds", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 3600,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 300},
              {"color": "green", "value": 900}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Self-mod commits (this life)",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_self_mod_commits_total", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"]},
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Journal entries",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_journal_entries_total", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"]},
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Inflight tasks",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_inflight_tasks", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"]},
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Claude invocations (rate / 5m)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(kenny_claude_invocations_total[5m])", "refId": "A", "legendFormat": "{{result}}"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Claude invocation duration (p95)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(kenny_claude_invocation_duration_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "p95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Life count over time",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_life_count_total", "refId": "A", "legendFormat": "lives"}
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Up?",
      "gridPos": {"x": 12, "y": 12, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "up{job=\"kenny\"}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Build SHA",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kenny_build_info", "refId": "A", "legendFormat": "{{sha}}"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "name"
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Kenny logs",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{job=\"kenny\"}", "refId": "A"}
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
